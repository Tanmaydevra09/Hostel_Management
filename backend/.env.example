# Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Server ──────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database (PlanetScale / any MySQL host) ──────────────────
DB_HOST=CHANGE_ME         # e.g. aws.connect.psdb.cloud
DB_PORT=3306
DB_USER=CHANGE_ME         # PlanetScale username
DB_PASSWORD=CHANGE_ME     # PlanetScale password
DB_NAME=CHANGE_ME         # PlanetScale database name
DB_SSL=true               # Set to true for PlanetScale

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_chars_random_string
JWT_EXPIRES_IN=24h

# ── File Upload ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Frontend URL (CORS) ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (Gmail SMTP + App Password) ───────────────────────
# Enable 2FA on Gmail → https://myaccount.google.com/apppasswords
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
